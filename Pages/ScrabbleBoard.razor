@page "/"
@inject ILogger<ScrabbleBoard> Logger
@inject HttpClient Http
@inject ScrabbleSK.Services.DictionaryService Dict
@using System.IO;
@using System.Reflection;
@using Microsoft.AspNetCore.Components;
@using ScrabbleSK.Data
@using ScrabbleSK.GameLog
@using ScrabbleSK.Pages
@using ScrabbleSK.Players
@using ScrabbleSK.Solver
@using ScrabbleSK.Stats
@using ScrabbleSK.Words
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<PageTitle>Scrabble</PageTitle>


@if (gameLog?.messages != null)
{
    <div class="message">
        @foreach (string s in gameLog.messages)
        {
            <GameLogger logmessage=@s></GameLogger>
        }
        </div>
}

@if (ShowHelp)
{
    <div style="position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000;">
        <div style="background:white; padding:1rem; max-width:800px; width:90%; border-radius:6px; position:relative;">
            <button class="btn btn-sm btn-link" style="position:absolute; right:8px; top:8px;" @onclick="CloseHelp">Zavrieť</button>
            <h3>Návod na hru</h3>
            <p>Vitajte v hre Scrabble. Tu sú základné pravidlá a tipy, ktoré vám pomôžu začať:</p>

            <h4>Základy</h4>
            <ul>
                <li>Tvorte slová horizontálne (vpravo) alebo vertikálne (nadol) tak, aby boli zmysluplné.</li>
                <li>Na každom ťahu môžete položiť 1 alebo viac písmen z vášho stojanu (rack).</li>
                <li>Ak použijete všetky písmená (7), získate bonus +50 bodov (bingo).</li>
            </ul>

            <h4>Skórovanie</h4>
            <ul>
                <li>Každé písmeno má bodovú hodnotu. Hodnoty nájdete v nastavení hry.</li>
                <li>Speciálne polia na doske násobia body písmen (DL/TL) alebo celého slova (DW/TW).</li>
            </ul>

            <h4>Žolík</h4>
            <ul>
                <li>Žolík je zastúpený znakom '#'. Nemá žiadnu bodovú hodnotu a môže zastúpiť ľubovoľné písmeno.</li>
            </ul>

            <h4>Ovládanie</h4>
            <ul>
                <li>Tlačidlo "Play" potvrdí položené písmená.</li>
                <li>Tlačidlo "Swap" vymení označené písmená za nové z vrecka (ak sú dostupné).</li>
                <li>Tlačidlo "Hint" navrhne možné ťahy (vyžaduje povolený slovník).</li>
            </ul>
        </div>
    </div>
}

<div class="game" id="game">
    <div class="game-element-container">
        <div class="board">
            @if (boardManager?.BoardTiles != null)
            {
                @for (int x = 0; x < BoardManager.BOARD_WIDTH; x++)
                {
                    <div class="tile-row">
                        @for (int y = 0; y < BoardManager.BOARD_HEIGHT; y++)
                        {
                            BoardTile boardTile = boardManager.BoardTiles[x, y];
                            <BoardSpace BoardTile=boardTile playerManager=playerManager OnClickCallback="@BoardTileClick"></BoardSpace>
                        }
                    </div>
                }
            }
            else
            {
                <div>Loading board...</div>
            }

            <p class="float-left mt-4">Počet zostávajúcich písmen:@(tileBag != null ? tileBag.LetterCountRemaining().ToString() : "0")</p>

            @if (SwapIsClicked)
            {
                <p class="float-right">Vyber písmená na výmenu"</p>
            }
        </div>
    </div>

    <div class="grid-element-container">
        <div class="player-tiles">
            <div class="tile-row">
                @if (playerManager?.CurrentPlayer?.Tiles != null)
                {
                    @for (int x = 0; x < RackManager.RACK_WIDTH; x++)
                    {
                        RackTile rackTile = playerManager.CurrentPlayer.Tiles[x];
                        <RackSpace RackTile=rackTile playerManager=playerManager OnClickCallback="@RackTileClick"></RackSpace>
                    }
                }
            </div>
        </div>
    </div>

    <div class="buttons mt-4 mb-2">
        <button class="@BtnColor" @onclick=Play>Play @PlayMessage</button>
        <button @onclick=Pass>Pass</button>
        <button @onclick=Swap>Swap</button>
        <button @onclick=Hint>Hint</button>
        <button @onclick=Valid>Valid</button>
        <button @onclick=InValid>InValid</button>
        <button @onclick=NewGame>NewGame</button>
          <button @onclick="() => ShowHelp = true">Návod na hru</button>
        <!--
        <button @onclick=Exit>Exit</button>
        <button @onclick=Test>Test</button>
        -->

    </div>
    <div>
        @if (tileBag != null)
        {
            <label>Joker:</label>
            <select @bind="tileBag.JokerBag">
                @if (tileBag.AbecedaSK != null)
                {
                    @foreach (char pismeno in tileBag.AbecedaSK)
                    {
                        <option value="@pismeno">@pismeno</option>
                    }
                }
            </select>
        }
        else
        {
            <div>Joker: Loading...</div>
        }
    </div>
</div




