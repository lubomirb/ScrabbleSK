    private string SolutionText(Solution solution)
    {
        string s = solution.dir + " ";

        string a = solution.w.ToString();
        while (a.Length < 4) a = " " + a;
        s += a;

        if (Array.IndexOf(solution.seq, '#') >= 0) s += "*";
        else s += " ";
        s += " ";

        s += solution.s;
        return s;
    }

    public void GameOver()
    {
        GamePlaying = false;
        string msg = "HRA SKONČILA";
        //streamLog.WriteLine(msg);
        gameLog.Log(msg);

        msg = "Písmená v zásobníku " + playerManager.CurrentPlayer.Name + ":";
        playerManager.CurrentPlayer.Tiles.ForEach(t => msg += $"{t.Text}");
        gameLog.Log(msg);

        foreach (RackTile t in playerManager.CurrentPlayer.Tiles)
        {
            if (!String.IsNullOrEmpty(t.Text))
                playerManager.CurrentPlayer.Score -= WordScorer.LetterValue(Char.Parse(t.Text.Substring(0, 1)));
        }
        msg = playerManager.CurrentPlayer.Name + " Výsledné skóre=" + playerManager.CurrentPlayer.Score.ToString();
        gameLog.Log(msg);
        //streamLog.WriteLine(msg);

        playerManager.SwapCurrentPlayer();
        msg = "Písmená v zásobníku " + playerManager.CurrentPlayer.Name + ":";
        playerManager.CurrentPlayer.Tiles.ForEach(t => msg += $"{t.Text}");
        gameLog.Log(msg);

        foreach (RackTile t in playerManager.CurrentPlayer.Tiles)
        {
            if (!String.IsNullOrEmpty(t.Text))
                playerManager.CurrentPlayer.Score -= WordScorer.LetterValue(Char.Parse(t.Text.Substring(0, 1)));
        }
        msg = playerManager.CurrentPlayer.Name + " Výsledné skóre=" + playerManager.CurrentPlayer.Score.ToString();
        gameLog.Log(msg);
        //streamLog.WriteLine(msg);

        msg = string.Empty;
        int lettersCount = 0;

        for (int x = 0; x <= BOARD_WIDTH - 1; x++)
        {
            msg = string.Empty;
            for (int y = 0; y <= BOARD_HEIGHT - 1; y++)
            {
                if (boardManager.BoardTiles[x, y].Text != String.Empty)
                {
                    msg += boardManager.BoardTiles[x, y].Text;
                    lettersCount++;
                }
                else msg += "+";
            }
            //streamLog.WriteLine(msg);
        }
        msg = "Počet vyložených písmen" + lettersCount.ToString();
        //streamLog.WriteLine(msg);

        //streamLog.Close();
        // fileStream.Close();
    }

    private void BoardTileClick(BoardTile boardTile)
    {
        var moveresult = wordValidator.ValidateAllWordsInPlay();
        if (moveresult.Valid)
            BtnColor = "btn-valid";
        else BtnColor = "btn-invalid";
        PlayMessage = moveresult.TotalScore.ToString() + " pts";

    }
