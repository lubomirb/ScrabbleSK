    static async Task<string> ReadStreamAsync(string filePath)
    {
        string text = string.Empty;

        Stream resourceStream = Assembly.GetExecutingAssembly().GetManifestResourceStream(filePath);
        using (StreamReader sr = new StreamReader(resourceStream))
        {
            text = await sr.ReadToEndAsync();
        }
        return text;
    }

    private async Task<string> ReadFileAsync(string fileName)
    {
        try
        {
            var content = await Http.GetStringAsync(fileName);
            return content;
        }
        catch (Exception ex)
        {
            return $"Error reading file {fileName}: {ex.Message}";
        }
    }

    private void ReRender()
    {
        StateHasChanged();
    }

    private void Valid()
    {
        wordValidator.Valid();
    }
    private void InValid()
    {
        Solution solution = Solutions[0];
        UndoSolution(solution);
        wordValidator.InValid(solution.s);
        PlayerTwoSolution();
        playerManager.SwapCurrentPlayer();
    }

    private void NewGame()
    {
        GamePlaying = true;
        SwapIsClicked = false;
        PlayMessage = string.Empty;

        statManager = new StatManager();

        tileBag = new BagTile();
        rackManager = new RackManager(tileBag);

        playerManager = new PlayerManager(rackManager);
        playerManager.SetupPlayers();

       
        boardManager = new BoardManager(tileBag, statManager, playerManager);
        boardManager.SetupTiles(initialBoard);

