        wordValidator = new WordValidator(tileBag, playerManager, boardManager, solverDictionary);
        gameLog = new GameLog();

    }

    private void Exit()
    {
        wordValidator.SaveInValidWords();
        //streamLog.Close();
    }

    private void Swap()
    {
        if (!GamePlaying) return;

        SwapIsClicked = false;
        var tiles = playerManager.CurrentPlayer.Tiles.Where(c => c.LetterSelected).ToList();
        if (tiles.Count == 0)
        {
            SwapIsClicked = true;
            gameLog.messages.Push("Vyber písmená na výmenu");
            return;
        }

        if (tiles.Count > tileBag.LetterCountRemaining())
        {
            gameLog.messages.Push("Môžeš výmeniť iba " + tileBag.LetterCountRemaining().ToString());
            return;
        }
        tiles.ForEach(t =>
        {
            tileBag.GiveLetter(t.Letter[0]);
            t.ClearDisplay();
        });
        ////streamLog.WriteLine(" Hrač si vymenil" + tiles.Count.ToString() + " písmen");
        rackManager.FillRack(playerManager.CurrentPlayer.Tiles);
        statManager.Swaps += 1;
        statManager.ConsecutivePasses = 0;
        playerManager.SwapCurrentPlayer();
        PlayerTwoSolution();
        playerManager.SwapCurrentPlayer();

    }
    private void Pass()
    {
        if (!GamePlaying) return;
        SwapIsClicked = false;

        statManager.Passes += 1;
        statManager.ConsecutivePasses += 1;
        if (statManager.ConsecutivePasses >= 4) GameOver();
        string msg = "H1 vynechal svoj ťah";
        gameLog.messages.Push(msg);
        ////streamLog.WriteLine(msg);

        playerManager.SwapCurrentPlayer();
        PlayerTwoSolution();
        playerManager.SwapCurrentPlayer();
    }
    private void Hint()
    {
        if (!GamePlaying) return;
        Napoveda();
    }
    private void Test()
    {
        if (!GamePlaying) return;
        PlayerTwoSolution();
        playerManager.SwapCurrentPlayer();
        PlayerTwoSolution();
        playerManager.SwapCurrentPlayer();
    }

        private void CloseHelp()
    {
        ShowHelp = false;
    }


    private void Play()
    {

        if (!GamePlaying) return;
        SwapIsClicked = false;

         string msg = string.Empty;
        msg = "H1 tiles =";
        foreach (RackTile t in playerManager.CurrentPlayer.Tiles)
        {
            msg += t.Text;
        }
         msg = "Počet zostávajúcich písmen" + tileBag.LetterCountRemaining().ToString();

        var tilesPlayed = playerManager.CurrentPlayer.Tiles.Where(r => string.IsNullOrEmpty(r.Text)).Count();
        if (tilesPlayed == 0)
        {
            return;
        }
        var checkTilePositions = boardManager.ValidateTilePositions();
        var moveResult = wordValidator.ValidateAllWordsInPlay();
        if (!checkTilePositions)
            gameLog.messages.Push("Slovo je zle umiestnené, vráť písmená do zásobníka a skús znova");
        else if (!moveResult.Valid)
            gameLog.messages.Push("Slovo nie je v slovníku, vráť písmená do zásobníka a skús znova");
        else
        {
            boardManager.ResetTilesInPlay();

            //LogRack(playerManager.CurrentPlayer.Tiles);

            rackManager.FillRack(playerManager.CurrentPlayer.Tiles);

            //LogRack(playerManager.CurrentPlayer.Tiles);


            msg = "Počet zostávajúcich písmen" + tileBag.LetterCountRemaining().ToString();
 


            statManager.Moves += 1;
            statManager.ConsecutivePasses = 0;

            if (tilesPlayed == 7)
                moveResult.TotalScore += 50;
            playerManager.CurrentPlayer.Score += moveResult.TotalScore;


            moveResult.Words.ForEach(m => playerManager.PlayedWords.Add(m));
            foreach (Word w in moveResult.Words)
            {
                if (tilesPlayed == 7 && w.Text.Length >= 7)
                    w.Score += 50;
            }

            msg = playerManager.CurrentPlayer.Name + ": ";
            moveResult.Words.ForEach(m => msg += $"{m.Text} {m.Score} ");
            msg += "skóre: " + playerManager.CurrentPlayer.Score;

            gameLog.Log(msg);
            //streamLog.WriteLine(msg);

            BtnColor = String.Empty;
            PlayMessage = String.Empty;

            if (rackManager.IsRackEmpty(playerManager.CurrentPlayer.Tiles))
            {
                GameOver();
                return;
            }
            playerManager.SwapCurrentPlayer();

            PlayerTwoSolution();
            if (rackManager.IsRackEmpty(playerManager.CurrentPlayer.Tiles))
            {
                GameOver();
                return;
            }
            playerManager.SwapCurrentPlayer();

        }

        StateHasChanged();

        // Solutions = solverBoard.findMoves(solverRack);
    }

    /// <summary>
    ///
    /// </summary>
    private void PlayerTwoSolution()
    {

        if (!GamePlaying) return;
        string msg = string.Empty;

        msg = "H2 tiles =";
        foreach (RackTile t in playerManager.CurrentPlayer.Tiles)
        {
            msg += t.Text;
        }
        //streamLog.WriteLine(msg);
        msg = "Počet zostávajúcich písmen" + tileBag.LetterCountRemaining().ToString();
        //streamLog.WriteLine(msg);

        //solverBag.importTileBag(tileBag.LettersRemaining());

        List<char> charList = new List<char>();
        foreach (RackTile rackTile in playerManager.CurrentPlayer.Tiles)
        {
            if (!String.IsNullOrEmpty(rackTile.Text))
            {
                charList.Add(rackTile.Text[0]);
            }
        }

        solverRack = new Rack(charList);


        int xLoc, yLoc;
        for (int x = 1; x <= BOARD_WIDTH; x++)
        {
            for (int y = 1; y <= BOARD_HEIGHT; y++)
            {
                xLoc = x - 1;
                yLoc = y - 1;

                // if (TileManager.Tiles[xLoc, yLoc].TileInPlay && TileManager.Tiles[xLoc, yLoc].Text != String.Empty)
                if (boardManager.BoardTiles[xLoc, yLoc].Text != String.Empty)
                {
                    char c = char.Parse(boardManager.BoardTiles[xLoc, yLoc].Text);
                    c = char.ToLower(c);
                    int? wrth = boardManager.BoardTiles[xLoc, yLoc].LetterValue;

                    Letter letter = new Letter(c, (int)wrth);
                    solverBoard[xLoc, yLoc] = letter;

                }
            }
        }

        solverBoard.maxL = 7;


        // gameLog = new GameLog();

        // progressBarDictionary.Value = 0;
        // progressBarDictionary.Visible = true;

        //Solutions
        Solutions = solverBoard.findMoves(solverRack);
        if (Solutions.Length == 0)
        {
            statManager.Passes += 1;
            statManager.ConsecutivePasses += 1;
            if (statManager.ConsecutivePasses >= 4)
            {
                GameOver();
                return;
            }
            msg = "H2 vynechal svoj ťah";
            gameLog.messages.Push(msg);
            return;
        }


        int i0 = 0;
        while (wordValidator.CheckInvalid(Solutions[i0].s))
        {
            i0++;
        }

        Solution solution = Solutions[i0];

        string seqSolution = new string(solution.seq);


        string msg1 = "s=" + solution.s + " seq=" + seqSolution + " w=" + solution.w.ToString() + " dir=" + solution.dir.ToString() + solution.x.ToString() + ";" + solution.y.ToString();
        //streamLog.WriteLine(msg1);

        // Place in on board
        int i = solution.x;
        int j = solution.y;
        lastTilesInPlay.Clear();

        foreach (char character in solution.seq)
        {
            if (solution.dir == 'H')
                while (boardManager.BoardTiles[i, j].Letter != string.Empty) j++;
            else if (solution.dir == 'V')
                while (boardManager.BoardTiles[i, j].Letter != string.Empty) i++;

            int wrth = WordScorer.LetterValue(char.ToUpper(character));
            boardManager.BoardTiles[i, j].Letter = char.ToUpper(character).ToString();

            char letter = character;
            if (character == '#')
            {
                letter = solution.s[(i - solution.x) + j - solution.y];
                boardManager.BoardTiles[i, j].Joker = true;
            }
            else
                boardManager.BoardTiles[i, j].Joker = false;
            boardManager.BoardTiles[i, j].Text = char.ToUpper(letter).ToString();
            boardManager.BoardTiles[i, j].LetterValue = wrth;
            boardManager.BoardTiles[i, j].TileInPlay = true;
            boardManager.BoardTiles[i, j].MatejPlayed = true;
            lastTilesInPlay.Add(boardManager.BoardTiles[i, j]);
        }

        var checkTilePositions = boardManager.ValidateTilePositions();
        var moveResult = wordValidator.ValidateAllWordsInPlay();
        if (!checkTilePositions)
            gameLog.messages.Push("Slovo je zle umiestnené, vráť písmená do zásobníka a skús znova");
        else if (!moveResult.Valid)
            gameLog.messages.Push("Slovo nie je v slovníku, vráť písmená do zásobníka a skús znova");
        else
        {
            boardManager.ResetTilesInPlay();

            rackManager.ClearRack(playerManager.CurrentPlayer.Tiles, seqSolution.ToUpper());

            //LogRack(playerManager.CurrentPlayer.Tiles);
            rackManager.FillRack(playerManager.CurrentPlayer.Tiles);
           // LogRack(playerManager.CurrentPlayer.Tiles);
 
            msg = "Počet zostávajúcich písmen" + tileBag.LetterCountRemaining().ToString();
 
            statManager.Moves += 1;
            statManager.ConsecutivePasses = 0;

            if (solution.seq.Length == 7)
                moveResult.TotalScore += 50;
            playerManager.CurrentPlayer.Score += moveResult.TotalScore;

            moveResult.Words.ForEach(m => playerManager.PlayedWords.Add(m));
            foreach (Word w in moveResult.Words)
                if (solution.seq.Length == 7 && w.Text.Length >= 7)
                    w.Score += 50;

            msg = playerManager.CurrentPlayer.Name + ": ";
            moveResult.Words.ForEach(m => msg += $"{m.Text} {m.Score} ");
            msg += "skóre: " + playerManager.CurrentPlayer.Score + " w=" + solution.w.ToString();

            gameLog.Log(msg);
        }
    }
