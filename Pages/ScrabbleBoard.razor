        rackTile.Text = string.Empty;

        //return Task.CompletedTask;

      //  Logger.LogInformation($"RackTileClick0 Parent Letter={rackTile.Letter} Text={rackTile.Text} LetterSelected ={rackTile.LetterSelected}");
    }

    void UndoSolution(Solution solution)
    {
        foreach (var tile in lastTilesInPlay)
        {
            boardManager.bagTile.GiveLetter(char.Parse(tile.Text));
            tile.Text = string.Empty;
            tile.Letter = string.Empty;
        }
        playerManager.CurrentPlayer.Score -= solution.w;
        boardManager.ClearTileHighlights();
    }

    void LogRack(List<RackTile> tile)
    {
        string msg = "tile=";
        foreach (RackTile t in tile)
        {
            msg += t.Text +t.Letter + t.LetterValue.ToString() + t.LetterSelected.ToString() + " " ;
        }
        gameLog.Log(msg);
    }
}